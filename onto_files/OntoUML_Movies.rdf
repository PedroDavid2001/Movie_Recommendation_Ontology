                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Movie_Recommendation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Negative_Genre_Preference -->

    <owl:Class rdf:about="http://example.com/MovieExample#Negative_Genre_Preference">
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Genre_Preference"/>
        <owl:disjointWith rdf:resource="http://example.com/MovieExample#Positive_Genre_Preference"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Positive_Genre_Preference -->

    <owl:Class rdf:about="http://example.com/MovieExample#Positive_Genre_Preference">
