<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.com/MovieExample#"
     xml:base="http://example.com/MovieExample"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:gufo="http://purl.org/nemo/gufo#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.com/MovieExample">
        <owl:imports rdf:resource="http://purl.org/nemo/gufo#"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.com/MovieExample#Recommends -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#Recommends">
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Movie_Recommendation_App"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#Movie"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#belongs_To_Genre -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#belongs_To_Genre">
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Movie"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#friend_Of -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#friend_Of">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://example.com/MovieExample#User"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#User"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#has_Genre_Preference -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#has_Genre_Preference">
        <rdfs:domain rdf:resource="http://example.com/MovieExample#User"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#mediatesGenre -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#mediatesGenre">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Genre_Preference"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#mediatesUser -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#mediatesUser">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Genre_Preference"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#User"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#receives_Recommendation_Of -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#receives_Recommendation_Of">
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Movie"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#User"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/MovieExample#recommends_To -->

    <owl:ObjectProperty rdf:about="http://example.com/MovieExample#recommends_To">
        <rdfs:domain rdf:resource="http://example.com/MovieExample#Movie_Recommendation_App"/>
        <rdfs:range rdf:resource="http://example.com/MovieExample#User"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.com/MovieExample#Action -->

    <owl:Class rdf:about="http://example.com/MovieExample#Action">
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#ActionMovie -->

    <owl:Class rdf:about="http://example.com/MovieExample#ActionMovie">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/MovieExample#Movie"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/MovieExample#belongs_To_Genre"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Action"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Comedy -->

    <owl:Class rdf:about="http://example.com/MovieExample#Comedy">
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#ComedyMovie -->

    <owl:Class rdf:about="http://example.com/MovieExample#ComedyMovie">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/MovieExample#Movie"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/MovieExample#belongs_To_Genre"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Comedy"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Drama -->

    <owl:Class rdf:about="http://example.com/MovieExample#Drama">
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#DramaMovie -->

    <owl:Class rdf:about="http://example.com/MovieExample#DramaMovie">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/MovieExample#Movie"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/MovieExample#belongs_To_Genre"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Drama"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Genre_Preference -->

    <owl:Class rdf:about="http://example.com/MovieExample#Genre_Preference">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Relator"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/MovieExample#User"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://example.com/MovieExample#Movie_Recommendation"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Horror -->

    <owl:Class rdf:about="http://example.com/MovieExample#Horror">
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie_Genre"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#HorrorMovie -->

    <owl:Class rdf:about="http://example.com/MovieExample#HorrorMovie">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/MovieExample#Movie"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/MovieExample#belongs_To_Genre"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Horror"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.com/MovieExample#Movie"/>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Movie -->

    <owl:Class rdf:about="http://example.com/MovieExample#Movie">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#FunctionalComplex"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Movie_Recommendation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Movie_Genre -->

    <owl:Class rdf:about="http://example.com/MovieExample#Movie_Genre">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#FunctionalComplex"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Genre_Preference"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Movie_Recommendation -->

    <owl:Class rdf:about="http://example.com/MovieExample#Movie_Recommendation">
        <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Relator"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#Movie"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:someValuesFrom rdf:resource="http://example.com/MovieExample#User"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/nemo/gufo#mediates"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.com/MovieExample#Movie_Recommendation_App"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.com/MovieExample#Movie_Recommendation_App -->

    <owl:Class rdf:about="http://example.com/MovieExample#Movie_Recommendation_App">
